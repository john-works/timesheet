<div class="card">
    <div class="card-body p-3 text-center">
        <div class="text-end text-muted">
            <i class="fas fa-clock fs-2"></i>
        </div>
        <div class="h2 mt-2 mb-0">{{ data }}</div>
        <div class="text-muted mb-2">Pending Weekly Approvals</div>
        {% if data > 0 %}
            <a href="{{ path('weekly_submission_supervisor_pending') }}" class="btn btn-warning btn-sm">Review Now</a>
        {% endif %}
    </div>
</div>
