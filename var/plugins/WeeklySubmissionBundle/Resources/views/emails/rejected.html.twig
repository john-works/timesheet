{% extends 'emails/layout.html.twig' %}

{% block title %}Weekly Timesheet Needs Attention{% endblock %}

{% block body %}
<p>
    Your weekly timesheet for <strong>{{ weekStart }} - {{ weekEnd }}</strong>
    has been <strong>rejected</strong>.
</p>
{% if submission.supervisorNotes %}
    <p><strong>Reason:</strong> {{ submission.supervisorNotes }}</p>
{% endif %}
<p>Please review the feedback, make any necessary corrections, and resubmit.</p>
<p>
    <a href="{{ url('weekly_submission_staff') }}">Click here to resubmit</a>
</p>
{% endblock %}
