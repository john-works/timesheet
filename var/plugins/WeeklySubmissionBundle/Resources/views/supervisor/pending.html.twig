{% extends 'base.html.twig' %}
{% import "macros/widgets.html.twig" as widgets %}

{% block main %}
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Pending My Approval</h3>
            </div>
            <div class="card-body p-0">
                {% if submissions|length == 0 %}
                    <div class="p-3">
                        <div class="alert alert-info mb-0">No pending submissions from your direct reports.</div>
                    </div>
                {% else %}
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Staff</th>
                                <th>Week</th>
                                <th>Total Hours</th>
                                <th>Submitted</th>
                                <th>Current User</th>
                                <th>Comment</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for submission in submissions %}
                            <tr>
                                <td>{{ submission.user.displayName }}</td>
                                <td>{{ submission.weekStart|date('d/m/Y') }} - {{ submission.weekStart|date_modify('+4 days')|date('d/m/Y') }}</td>
                                <td>
                                    {% set hours = (submission.totalDuration / 3600)|number_format(2) %}{{ hours }}h
                                </td>
                                <td>{{ submission.submittedAt ? submission.submittedAt|date('d/m/Y H:i') : '-' }}</td>
                                <td>{{ submission.currentApprover ? submission.currentApprover.displayName : '-' }}</td>
                                <td>{{ submission.managerNotes ?: (submission.supervisorNotes ?: '-') }}</td>
                                <td class="actions-cell">
                                    <div class="dropdown">
                                        <a href="#" data-bs-toggle="dropdown" style="text-decoration:none">
                                            <i class="fas fa-bars" style="color:blue"></i>
                                        </a>
                                        <div class="dropdown-menu dropdown-menu-right">
                                            <a href="{{ path('weekly_submission_supervisor_view_modal', {id: submission.id}) }}" class="dropdown-item remote-modal-load" data-modal-title="Timesheet - {{ submission.user.displayName }}" data-modal-class="p-0">
                                                <i class="fas fa-eye" style="color:#0056b3;width:1.5rem"></i> View
                                            </a>
                                            {% if submission.id in actableIds %}
                                            <div class="dropdown-divider"></div>
                                            <a href="#" class="dropdown-item" onclick="event.preventDefault();" data-bs-toggle="modal" data-bs-target="#approveModal{{ submission.id }}">
                                                <i class="fas fa-check" style="color:#28a745;width:1.5rem"></i> Approve
                                            </a>
                                            <a href="#" class="dropdown-item" onclick="event.preventDefault();" data-bs-toggle="modal" data-bs-target="#rejectModal{{ submission.id }}">
                                                <i class="fas fa-times" style="color:#dc3545;width:1.5rem"></i> Reject
                                            </a>
                                            {% endif %}
                                        </div>
                                    </div>

                                    <div class="modal fade" id="approveModal{{ submission.id }}" tabindex="-1">
                                        <div class="modal-dialog">
                                            <div class="modal-content">
                                                <form action="{{ path('weekly_submission_supervisor_approve', {id: submission.id}) }}" method="post" >
                                                    <div class="modal-header">
                                                        <h5 class="modal-title">Approve - {{ submission.user.displayName }}</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                    </div>
                                                    <div class="modal-body">
                                                        <div class="mb-3">
                                                            <strong>Week:</strong> {{ submission.weekStart|date('d/m/Y') }} - {{ submission.weekStart|date_modify('+4 days')|date('d/m/Y') }}
                                                        </div>
                                                        <div class="mb-3">
                                                            <strong>Total hours:</strong> {{ (submission.totalDuration / 3600)|number_format(2) }}h
                                                        </div>
                                                        <div class="mb-3">
                                                            <label for="notes{{ submission.id }}" class="form-label">Notes (optional)</label>
                                                            <textarea id="notes{{ submission.id }}" name="notes" class="form-control" rows="3"></textarea>
                                                        </div>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                        <button type="submit" class="btn btn-success" onclick="this.disabled=true;this.form.submit();">Confirm Approve</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="modal fade" id="rejectModal{{ submission.id }}" tabindex="-1">
                                        <div class="modal-dialog">
                                            <div class="modal-content">
                                                <form action="{{ path('weekly_submission_supervisor_reject', {id: submission.id}) }}" method="post" >
                                                    <div class="modal-header">
                                                        <h5 class="modal-title">Reject - {{ submission.user.displayName }}</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                    </div>
                                                    <div class="modal-body">
                                                        <div class="mb-3">
                                                            <strong>Week:</strong> {{ submission.weekStart|date('d/m/Y') }} - {{ submission.weekStart|date_modify('+4 days')|date('d/m/Y') }}
                                                        </div>
                                                        <div class="mb-3">
                                                            <strong>Total hours:</strong> {{ (submission.totalDuration / 3600)|number_format(2) }}h
                                                        </div>
                                                        <div class="mb-3">
                                                            <label for="rejectNotes{{ submission.id }}" class="form-label">Reason for rejection <span class="text-danger">*</span></label>
                                                            <textarea id="rejectNotes{{ submission.id }}" name="notes" class="form-control" rows="3" required></textarea>
                                                        </div>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                        <button type="submit" class="btn btn-danger" onclick="setTimeout(() => this.disabled = true, 0)">Confirm Reject</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% endif %}
            </div>
        </div>
    </div>
</div>

{% if managerSubmissions|length > 0 %}
<div class="row mt-3">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Awaiting Final Approval</h3>
                <div class="card-tools">
                    <span class="badge bg-info">{{ managerSubmissions|length }} pending</span>
                </div>
            </div>
            <div class="card-body p-0">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Staff</th>
                            <th>Week</th>
                            <th>Total Hours</th>
                            <th>Supervisor</th>
                            <th>Approved At</th>
                            <th>Comment</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for submission in managerSubmissions %}
                        <tr>
                            <td>{{ submission.user.displayName }}</td>
                            <td>{{ submission.weekStart|date('d/m/Y') }} - {{ submission.weekStart|date_modify('+4 days')|date('d/m/Y') }}</td>
                            <td>
                                {% set hours = (submission.totalDuration / 3600)|number_format(2) %}{{ hours }}h
                            </td>
                            <td>{{ submission.approvedBy ? submission.approvedBy.displayName : '-' }}</td>
                            <td>{{ submission.approvedAt ? submission.approvedAt|date('d/m/Y H:i') : '-' }}</td>
                            <td>{{ submission.managerNotes ?: (submission.supervisorNotes ?: '-') }}</td>
                            <td class="actions-cell">
                                <div class="dropdown">
                                        <a href="#" data-bs-toggle="dropdown" style="text-decoration:none">
                                            <i class="fas fa-bars" style="color:blue"></i>
                                        </a>
                                    <div class="dropdown-menu dropdown-menu-right">
                                        <a href="{{ path('weekly_submission_supervisor_view_modal', {id: submission.id}) }}" class="dropdown-item remote-modal-load" data-modal-title="Timesheet - {{ submission.user.displayName }}" data-modal-class="p-0">
                                            <i class="fas fa-eye" style="color:#0056b3;width:1.5rem"></i> View
                                        </a>
                                        {% if submission.id in managerActableIds %}
                                        <div class="dropdown-divider"></div>
                                        <a href="#" class="dropdown-item" onclick="event.preventDefault();" data-bs-toggle="modal" data-bs-target="#finalApproveModal{{ submission.id }}">
                                            <i class="fas fa-check" style="color:#28a745;width:1.5rem"></i> Final Approve
                                        </a>
                                        <a href="#" class="dropdown-item" onclick="event.preventDefault();" data-bs-toggle="modal" data-bs-target="#rejectModal{{ submission.id }}">
                                            <i class="fas fa-times" style="color:#dc3545;width:1.5rem"></i> Reject
                                        </a>
                                        {% endif %}
                                    </div>
                                </div>

                                <div class="modal fade" id="finalApproveModal{{ submission.id }}" tabindex="-1">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <form action="{{ path('weekly_submission_supervisor_approve', {id: submission.id}) }}" method="post" >
                                                <div class="modal-header bg-success text-white">
                                                    <h5 class="modal-title">Final Approve - {{ submission.user.displayName }}</h5>
                                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body">
                                                    <div class="alert alert-info">
                                                        Approved by the supervisor 
                                                        ({{ submission.approvedBy ? submission.approvedBy.displayName : 'N/A' }}).
                                            
                                                    </div>
                                                    <div class="mb-3">
                                                        <strong>Week:</strong> {{ submission.weekStart|date('d/m/Y') }} - {{ submission.weekStart|date_modify('+4 days')|date('d/m/Y') }}
                                                    </div>
                                                    <div class="mb-3">
                                                        <strong>Total hours:</strong> {{ (submission.totalDuration / 3600)|number_format(2) }}h
                                                    </div>
                                                    <div class="mb-3">
                                                        <label for="managerNotes{{ submission.id }}" class="form-label">Notes (optional)</label>
                                                        <textarea id="managerNotes{{ submission.id }}" name="notes" class="form-control" rows="3"></textarea>
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                    <button type="submit" class="btn btn-success" onclick="this.disabled=true;this.form.submit();">Confirm Final Approve</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>

                                <div class="modal fade" id="rejectModal{{ submission.id }}" tabindex="-1">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <form action="{{ path('weekly_submission_supervisor_reject', {id: submission.id}) }}" method="post" >
                                                <div class="modal-header bg-danger text-white">
                                                    <h5 class="modal-title">Reject - {{ submission.user.displayName }}</h5>
                                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body">
                                                    <div class="mb-3">
                                                        <strong>Week:</strong> {{ submission.weekStart|date('d/m/Y') }} - {{ submission.weekStart|date_modify('+4 days')|date('d/m/Y') }}
                                                    </div>
                                                    <div class="mb-3">
                                                        <strong>Total hours:</strong> {{ (submission.totalDuration / 3600)|number_format(2) }}h
                                                    </div>
                                                    <div class="mb-3">
                                                        <label for="rejectNotes{{ submission.id }}" class="form-label">Reason for rejection <span class="text-danger">*</span></label>
                                                        <textarea id="rejectNotes{{ submission.id }}" name="notes" class="form-control" rows="3" required></textarea>
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                    <button type="submit" class="btn btn-danger" onclick="setTimeout(() => this.disabled = true, 0)">Confirm Reject</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endif %}

<style>
.actions-cell { white-space: nowrap; }
.actions-cell .dropdown-item:hover { background:#0056b3; color:#fff !important; }
.actions-cell .dropdown-item:hover i { color:#fff !important; }
</style>
{% endblock %}
