<div class="row mb-3">
    <div class="col-md-4">
        <strong>Staff:</strong> {{ submission.user.displayName }}
    </div>
    <div class="col-md-4">
        <strong>Week:</strong> {{ weekStart|date('d/m/Y') }} - {{ weekEnd|date('d/m/Y') }}
    </div>
    <div class="col-md-4">
        <strong>Total:</strong>
        <span class="badge bg-primary">{{ (submission.totalDuration / 3600)|number_format(2) }}h</span>
    </div>
</div>

{% if timesheets|length == 0 %}
    <div class="alert alert-info">No timesheet entries found.</div>
{% else %}
    <table class="table table-striped table-sm">
        <thead>
            <tr>
                <th>Date</th>
                <th>Project</th>
                <th>Activity</th>
                <th>Description</th>
                <th>Duration</th>
                <th>Rate</th>
            </tr>
        </thead>
        <tbody>
            {% for entry in timesheets %}
            <tr>
                <td>{{ entry.begin|date('d/m/Y') }}</td>
                <td>{{ entry.project ? entry.project.name : '-' }}</td>
                <td>{{ entry.activity ? entry.activity.name : '-' }}</td>
                <td>{{ entry.description ?: '-' }}</td>
                <td>{{ (entry.duration / 3600)|number_format(2) }}h</td>
                <td>{{ entry.rate|number_format(2) }}</td>
            </tr>
            {% endfor %}
        </tbody>
        <tfoot>
            <tr class="fw-bold">
                <td colspan="4" class="text-end">Total:</td>
                <td>{{ (submission.totalDuration / 3600)|number_format(2) }}h</td>
                <td>{{ timesheets|reduce((carry, ts) => carry + ts.rate, 0)|number_format(2) }}</td>
            </tr>
        </tfoot>
    </table>
{% endif %}
