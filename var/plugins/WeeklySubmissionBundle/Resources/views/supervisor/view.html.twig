{% extends 'base.html.twig' %}
{% import "macros/widgets.html.twig" as widgets %}

{% block main %}
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Timesheet Details - {{ submission.user.displayName }}</h3>
                <div class="card-tools">
                    <a href="{{ path('weekly_submission_supervisor_pending') }}" class="btn btn-secondary btn-sm">
                        <i class="fas fa-arrow-left"></i> Back to Pending
                    </a>
                </div>
            </div>
            <div class="card-body">
                <div class="row mb-4">
                    <div class="col-md-3">
                        <strong>Staff:</strong><br>
                        {{ submission.user.displayName }}
                    </div>
                    <div class="col-md-3">
                        <strong>Week:</strong><br>
                        {{ weekStart|date('d/m/Y') }} - {{ weekEnd|date('d/m/Y') }}
                    </div>
                    <div class="col-md-3">
                        <strong>Total Hours:</strong><br>
                        <span class="badge bg-primary" style="font-size: 1.1em;">{{ (totalDuration / 3600)|number_format(2) }}h</span>
                    </div>
                    <div class="col-md-3">
                        <strong>Status:</strong><br>
                        {% if submission.isSubmitted %}
                            <span class="badge bg-primary">Pending Supervisor Approval</span>
                        {% elseif submission.isSupervisorApproved %}
                            <span class="badge bg-info">Supervisor Approved - Pending Final Approval</span>
                        {% elseif submission.isApproved %}
                            <span class="badge bg-success">Approved</span>
                        {% elseif submission.isRejected %}
                            <span class="badge bg-danger">Rejected</span>
                        {% endif %}
                    </div>
                </div>

                {% if timesheets|length == 0 %}
                    <div class="alert alert-info">No timesheet entries found for this period.</div>
                {% else %}
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Project</th>
                                <th>Activity</th>
                                <th>Description</th>
                                <th>Start Time</th>
                                <th>End Time</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for entry in timesheets %}
                            {% set isLeave = entry.activity is not null and entry.activity.name|lower == 'leave' %}
                            <tr class="{{ isLeave ? 'table-info' : '' }}">
                                <td>{{ entry.begin|date('d/m/Y') }}</td>
                                <td>{{ entry.project ? entry.project.name : '-' }}</td>
                                <td>
                                    {{ entry.activity ? entry.activity.name : '-' }}
                                    {% if isLeave %}
                                        <span class="badge bg-info">On Leave</span>
                                    {% endif %}
                                </td>
                                <td>{{ entry.description ?: '-' }}</td>
                                <td>{{ entry.begin|date('h:i A') }}</td>
                                <td>{{ entry.end ? entry.end|date('h:i A') : '-' }}</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                        <tfoot>
                            <tr class="fw-bold">
                                <td colspan="5" class="text-end">Total:</td>
                                <td>{{ (totalDuration / 3600)|number_format(2) }}h</td>
                            </tr>
                        </tfoot>
                    </table>
                {% endif %}
            </div>
            {% if (canAct and submission.isSubmitted) or (canActManager and submission.isSupervisorApproved) %}
                <div class="card-footer text-center">
                    {% if canAct and submission.isSubmitted %}
                    <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#approveModal{{ submission.id }}">
                        <i class="fas fa-check"></i> Approve
                    </button>
                    {% endif %}
                    {% if canActManager and submission.isSupervisorApproved %}
                    <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#finalApproveModal{{ submission.id }}">
                        <i class="fas fa-check"></i> Final Approve
                    </button>
                    {% endif %}
                    <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#rejectModal{{ submission.id }}">
                        <i class="fas fa-times"></i> Reject
                    </button>
                </div>
            {% endif %}
        </div>
    </div>
</div>

{% if canAct and submission.isSubmitted %}
<div class="modal fade" id="approveModal{{ submission.id }}" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="{{ path('weekly_submission_supervisor_approve', {id: submission.id}) }}" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Approve - {{ submission.user.displayName }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <strong>Week:</strong> {{ weekStart|date('d/m/Y') }} - {{ weekEnd|date('d/m/Y') }}
                    </div>
                    <div class="mb-3">
                        <strong>Total hours:</strong> {{ (submission.totalDuration / 3600)|number_format(2) }}h
                    </div>
                    <div class="mb-3">
                        <label for="notes{{ submission.id }}" class="form-label">Notes (optional)</label>
                        <textarea id="notes{{ submission.id }}" name="notes" class="form-control" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Confirm Approve</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endif %}

{% if canActManager and submission.isSupervisorApproved %}
<div class="modal fade" id="finalApproveModal{{ submission.id }}" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="{{ path('weekly_submission_supervisor_approve', {id: submission.id}) }}" method="post">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">Final Approve - {{ submission.user.displayName }}</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info">
                        This submission has been approved by the supervisor ({{ submission.approvedBy ? submission.approvedBy.displayName : 'N/A' }}).
                        Your approval will finalize it.
                    </div>
                    <div class="mb-3">
                        <strong>Week:</strong> {{ weekStart|date('d/m/Y') }} - {{ weekEnd|date('d/m/Y') }}
                    </div>
                    <div class="mb-3">
                        <strong>Total hours:</strong> {{ (submission.totalDuration / 3600)|number_format(2) }}h
                    </div>
                    <div class="mb-3">
                        <label for="managerNotes{{ submission.id }}" class="form-label">Notes (optional)</label>
                        <textarea id="managerNotes{{ submission.id }}" name="notes" class="form-control" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Confirm Final Approve</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endif %}

<div class="modal fade" id="rejectModal{{ submission.id }}" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="{{ path('weekly_submission_supervisor_reject', {id: submission.id}) }}" method="post">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Reject - {{ submission.user.displayName }}</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <strong>Week:</strong> {{ weekStart|date('d/m/Y') }} - {{ weekEnd|date('d/m/Y') }}
                    </div>
                    <div class="mb-3">
                        <strong>Total hours:</strong> {{ (submission.totalDuration / 3600)|number_format(2) }}h
                    </div>
                    <div class="mb-3">
                        <label for="rejectNotes{{ submission.id }}" class="form-label">Reason for rejection <span class="text-danger">*</span></label>
                        <textarea id="rejectNotes{{ submission.id }}" name="notes" class="form-control" rows="3" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Confirm Reject</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
